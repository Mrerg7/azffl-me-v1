---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AZFFL — Arizona Female Foot Lover. A poetic meditation on the quiet worship of the feminine sole in the desert Southwest.', ogImage } = Astro.props;
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalURL = new URL(pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#F9F5F0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="a67V1Mq3oPXrFrqvec7O33wOwkueopd8nH_AzM4S5c4" />

    <!-- Preconnect to CDN -->
    <link rel="preconnect" href="https://imagedelivery.net" />

    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&amp;family=Playfair+Display:wght@700&amp;display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body class="bg-[#F9F5F0] text-[#1F1A17] antialiased">
    <!-- Navigation -->
    <div class="border-b border-[#EDE4D8] bg-white/80 backdrop-blur-sm sticky top-0 z-50" id="navbar">
      <div class="max-w-4xl mx-auto px-6 py-5 flex items-center justify-between">
        <div class="flex items-center gap-x-3">
          <div class="w-8 h-8 rounded-full bg-[#9F5A3C] flex items-center justify-center">
            <span class="text-white text-sm font-serif tracking-tighter">A</span>
          </div>
          <div>
            <span class="font-['Playfair_Display'] text-2xl font-semibold tracking-tighter text-[#1F1A17]">azffl</span>
          </div>
        </div>
        <div class="text-xs uppercase tracking-[3px] text-[#6B5F57] font-medium">Arizona • Female • Foot Lover</div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-[#EDE4D8]">
      <div class="max-w-4xl mx-auto px-6 py-10">
        <!-- Domain Acquisition CTA -->
        <div class="bg-gradient-to-r from-[#1F1A17] via-[#2D251F] to-[#1F1A17] rounded-2xl p-8 md:p-10 mb-8 text-center border border-[#4A3F36]">
          <div class="inline-block px-4 py-1 bg-white/10 rounded-full text-xs font-medium tracking-wider text-white/70 mb-4">
            PREMIUM DOMAIN AVAILABLE
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">
            Acquire azffl.me
          </h3>
          <p class="text-white/60 max-w-lg mx-auto mb-6">
            A rare, evocative .me domain with built-in brand resonance. Own the definitive digital identity for this unique expression of Southwest aesthetic appreciation.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="mailto:sales@desertrich.com?subject=Acquisition%20Inquiry%20-%20azffl.me"
              class="inline-flex items-center justify-center gap-x-2 px-8 py-3 bg-[#9F5A3C] hover:bg-[#864C31] text-white font-semibold rounded-xl transition-all"
            >
              <span>Inquire: sales@desertrich.com</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>
            <button
              id="copyEmailBtn"
              class="inline-flex items-center justify-center gap-x-2 px-6 py-3 border border-white/20 hover:bg-white/5 text-white font-medium rounded-xl transition-all text-sm"
              onclick="copyEmail()"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Copy Email
            </button>
          </div>
          <p class="mt-6 text-xs text-white/40">
            Serious inquiries only. This premium .me domain represents a unique acquisition opportunity.
          </p>
        </div>

        <!-- Bottom: Disclaimer + Info -->
        <div class="border-t border-[#EDE4D8] pt-8">
          <p class="text-xs text-[#8A7666] mb-6 leading-relaxed max-w-3xl">
            <strong>Disclaimer:</strong> This website is for demonstration and informational purposes only. It does not constitute an offer of services,
            a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
            technologies are based on publicly available information as of the date shown and are subject to change.
          </p>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-y-2 text-xs text-[#8A7666]">
            <div>
              <p>© 2026 AZFFL &mdash; A premium domain available for acquisition.</p>
            </div>
            <div class="flex items-center gap-x-4">
              <span class="font-mono tracking-widest">azffl.me</span>
              <span class="hidden md:inline">&bull;</span>
              <span>Phoenix, Arizona</span>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script>
      function copyEmail() {
        const email = 'sales@desertrich.com';
        navigator.clipboard.writeText(email).then(() => {
          const btn = document.getElementById('copyEmailBtn');
          if (btn) {
            const original = btn.innerHTML;
            btn.innerHTML = '<span>Copied to clipboard!</span>';
            btn.classList.add('bg-green-600', 'border-green-500');
            setTimeout(() => {
              btn.innerHTML = original;
              btn.classList.remove('bg-green-600', 'border-green-500');
            }, 2200);
          }
        }).catch(() => {
          window.location.href = 'mailto:' + email;
        });
      }

      // Sticky nav shadow on scroll
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (nav) {
          if (window.scrollY > 20) {
            nav.classList.add('shadow-sm');
          } else {
            nav.classList.remove('shadow-sm');
          }
        }
      });

      // Keyboard shortcut: / to scroll to top
      document.addEventListener('keydown', function(e) {
        if (e.key === '/' && document.activeElement === document.body) {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      console.log('%c[AZFFL] Elegant domain acquisition landing page ready.', 'color:#9F5A3C');
    </script>
  </body>
</html>
